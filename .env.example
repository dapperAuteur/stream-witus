# Stream.WitUS environment. Copy to .env.local and fill in. See plans/user-tasks/.
# All values are validated by src/lib/env.ts (fails fast on missing required vars).

# ── Database (Neon) — required. This project's Vercel–Neon integration provisions
# these STORAGE_-prefixed; the plain / POSTGRES_ forms are also accepted. ────────
STORAGE_DATABASE_URL="postgres://user:pass@host/db?sslmode=require"
STORAGE_DATABASE_URL_UNPOOLED="postgres://user:pass@host/db?sslmode=require"

# ── Better Auth (magic-link) — required ──────────────────────────────────────────
BETTER_AUTH_SECRET="generate-a-32+-char-random-secret"
BETTER_AUTH_URL="http://localhost:3050"
NEXT_PUBLIC_APP_URL="http://localhost:3050"
# TRUSTED_ORIGINS="https://stream.witus.online"
# PRODUCT_OWNER_USER_ID=""   # the single owner — used by the Phase 7 outbox owner-gate

# ── Email (Mailgun) — optional; magic links log to the console until set ─────────
# MAILGUN_API_KEY=""
# MAILGUN_DOMAIN=""
# MAILGUN_REGION="us"
# MAIL_FROM="Stream.WitUS <no-reply@witus.online>"

# ── Metadata APIs (Phase 4) — Open Library needs no key ──────────────────────────
# TMDB_API_KEY=""

# ── Cloudinary (covers + audio notes; Phase 3/5) — optional ──────────────────────
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# ── Ecosystem outbox / inbox (Phase 7) — off until configured ────────────────────
# OUTBOX_INGEST_URL=""
# OUTBOX_SOURCE_SLUG="stream-witus"
# OUTBOX_INGEST_SECRET=""
# OUTBOX_TRIGGER_ENABLED="false"
# INBOX_INGEST_URL=""
# INBOX_SOURCE_SLUG="stream-witus"
# INBOX_INGEST_SECRET=""
